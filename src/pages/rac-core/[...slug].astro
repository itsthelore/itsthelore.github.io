---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildRacCoreNav } from '../../lib/rac-core-nav';

export async function getStaticPaths() {
  const nav = await buildRacCoreNav();
  return nav.map((item) => ({
    params: { slug: item.slug },
    props: { item, nav },
  }));
}

const { item, nav } = Astro.props;
const { Content } = await render(item.entry);
---
<BaseLayout title={`${item.title} — rac-core docs`}>
  <div class="docs-sidebar">
    <nav class="docs-nav">
      <a class="back" href="/rac-core/">&larr; All rac-core docs</a>
      <ul>
        {nav.map((navItem) => (
          <li>
            <a
              href={`/rac-core/${navItem.slug}/`}
              aria-current={navItem.slug === item.slug ? 'page' : undefined}
            >
              {navItem.title}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <article class="prose">
      <Content />
    </article>
  </div>
</BaseLayout>
