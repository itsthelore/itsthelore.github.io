---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Lore — itsthelore">
  <div class="hero">
    <div class="hero__lead">
      <img
        class="hero__mascot"
        src="/images/lamplighter.png"
        alt="The Lore lamplighter, lantern raised"
        width="180"
        height="142"
      />
      <div class="hero__intro">
        <p class="eyebrow">Lore</p>
        <h1>Give your coding agent the decisions your team already made — so it stops re-doing things you ruled out.</h1>
        <p class="hero__sub">Agents that know why.</p>
      </div>
    </div>

    <div class="install">
      <span class="install__prompt">$</span>
      <code>pip install rac-core</code>
    </div>

    <nav class="btn-row" aria-label="Get started">
      <a class="btn btn--primary" href="/rac-core/quickstart/">Quickstart</a>
      <a class="btn" href="/rac-core/mcp/">MCP Server</a>
      <a class="btn" href="/rac-core/cli/">CLI Reference</a>
      <a class="btn btn--ghost" href="https://github.com/itsthelore">GitHub</a>
    </nav>
  </div>

  <div class="card-grid">
    <a class="card" href="/rac-core/">
      <h3>rac-core</h3>
      <p>The RAC engine and CLI — artifact schemas, validation, relationships, and the corpus toolchain.</p>
      <span class="tag tag--live">Live</span>
    </a>
    <div class="card disabled">
      <h3>rac-ci</h3>
      <p>CI delivery — Watchkeeper, Gatekeeper, and audit actions.</p>
      <span class="tag">Coming soon</span>
    </div>
    <div class="card disabled">
      <h3>rac-connectors</h3>
      <p>Inbound and outbound integrations.</p>
      <span class="tag">Coming soon</span>
    </div>
  </div>
</BaseLayout>
