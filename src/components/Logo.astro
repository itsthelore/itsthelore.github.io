---
interface Props {
  size?: number;
}
const { size = 24 } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <rect width="32" height="32" rx="8" fill="url(#logo-gradient)" />
  <path d="M10 8.5h3.4v12.1h8.2v3H10z" fill="#081019" />
  <defs>
    <linearGradient id="logo-gradient" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#7cc4ff" />
      <stop offset="1" stop-color="#3d7ab8" />
    </linearGradient>
  </defs>
</svg>
